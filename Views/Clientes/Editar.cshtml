@*
    Vista creada para editar un Cliente registrado en el sistema
*@
@model SICOVWEB_MCA.Models.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<section class="contenedor-principal">
    <div class="header-seccion">
        <h2>Editar Cliente</h2>
        <a asp-controller="Clientes" asp-action="Buscar" class="btn-primario"><i class="bi bi-arrow-left"></i> Regresar</a>
    </div>
<hr />
<!-- Formulario para editar un cliente existente -->

   
    <form asp-controller="Clientes" asp-action="Editar" method="post">
        <input type="hidden" asp-for="Id_cliente" />
        <div class="form-grid">
            <div>
                <label asp-for="Razon_Social"></label>
                <input type="text" asp-for="Razon_Social" class="campo-formulario" />
                <span asp-validation-for="Razon_Social" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Rfc"></label>
                <input type="text" asp-for="Rfc" class="campo-formulario" />
                <span asp-validation-for="Rfc" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Correo"></label>
                <input type="text" asp-for="Correo" class="campo-formulario" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Telefono"></label>
                <input type="text" asp-for="Telefono" class="campo-formulario" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Calle"></label>
                <input type="text" asp-for="Calle" class="campo-formulario" />
                <span asp-validation-for="Calle" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Numero"></label>
                <input type="text" asp-for="Numero" class="campo-formulario" />
                <span asp-validation-for="Numero" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Colonia"></label>
                <input type="text" asp-for="Colonia" class="campo-formulario" />
                <span asp-validation-for="Colonia" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Localidad"></label>
                <input type="text" asp-for="Localidad" class="campo-formulario" />
                <span asp-validation-for="Localidad" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Estado"></label>
                <input type="text" asp-for="Estado" class="campo-formulario" />
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Pais"></label>
                <input type="text" asp-for="Pais" class="campo-formulario" />
                <span asp-validation-for="Pais" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CP"></label>
                <input type="text" asp-for="CP" class="campo-formulario" />
                <span asp-validation-for="CP" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Condicion_Pago"></label>
                <input type="text" asp-for="Condicion_Pago" class="campo-formulario" />
                <span asp-validation-for="Condicion_Pago" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Estatus"></label>
                <input type="text" asp-for="Estatus" class="campo-formulario" />
                <span asp-validation-for="Estatus" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Tipo"></label>
                <select asp-for="Tipo" class="form-control">
                    <option value="">Seleccione</option>
                    <option value="moral">Moral</option>
                    <option value="fisica">Física</option>
                </select>
                <span asp-validation-for="Tipo" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Fecha_Alta"></label>
                <input asp-for="Fecha_Alta" type="date" class="campo-formulario" readonly />
                <span asp-validation-for="Fecha_Alta" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Fecha_Baja"></label>
                <input asp-for="Fecha_Baja" type="date" class="campo-formulario" />
                <span asp-validation-for="Fecha_Baja" class="text-danger"></span>
            </div>
        </div>
       
        <!-- Botonera -->
        <div class="acciones-formulario">
            <!-- Boton guardar  -->
            <button type="submit" class="btn-primario"><i class="bi bi-floppy"></i> Guardar cambios</button>
        </div>
    </form>
</section>

<!-- Recibir mensajes tempdata del controlador -->
@if (TempData["Mensaje"] != null)
{
    <script>
        alert('@TempData["Mensaje"]');
    </script>
}