@model SICOVWEB_MCA.Models.Proveedor

@*
    Vista para eliminar un proveedor registrado en el sistema
*@

@{
    ViewData["Title"] = "Eliminar Proveedor";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<section class="contenedor-principal">
    <div class="header-seccion">
        <h2>Eliminar Proveedor</h2>
        <a asp-controller="Proveedores" asp-action="ListaProveedores" class="btn-secundario"><i class="bi bi-arrow-left"></i> Regresar</a>
    </div>
<hr />
    <form asp-controller="Proveedores" asp-action="EliminarConfirmado" method="post">
        <!-- Inputs ocultos  -->
        <input type="hidden" asp-for="IdProveedor"/>

        <div class="form-grid">
            <div>
                <label asp-for="IdProveedor"></label>
                <input asp-for="IdProveedor" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Razon_social"></label>
                <input asp-for="Razon_social" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Rfc"></label>
                <input asp-for="Rfc" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Correo"></label>
                <input asp-for="Correo" class="campo-formulario" disabled />
            </div>

            <div>
                <label asp-for="Telefono"></label>
                <input asp-for="Telefono" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Calle"></label>
                <input asp-for="Calle" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Numero"></label>
                <input asp-for="Numero" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Colonia"></label>
                <input asp-for="Colonia" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Localidad"></label>
                <input asp-for="Localidad" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Estado"></label>
                <input asp-for="Estado" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Pais"></label>
                <input type="text" asp-for="Pais" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="CP"></label>
                <input type="text" asp-for="CP" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Condicion_pago"></label>
                <input type="text" asp-for="Condicion_pago" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Fecha_alta"></label>
                <input asp-for="Fecha_alta" type="date" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Fecha_baja"></label>
                <input asp-for="Fecha_baja" type="date" class="campo-formulario" disabled />
            </div>
            <div>
                <label asp-for="Estatus"></label>
                <input type="text" asp-for="Estatus" class="campo-formulario" disabled />
            </div>
        </div>
        <br />
        <!-- Botonera -->
        <div class="acciones-formulario">
            <!-- Boton Eliminar  -->
            <button type="submit" class="btn-primario"><i class="bi bi-trash"></i> Eliminar</button>
        </div>
    </form>
</section>
