@*
    Vista Listado de productos
*@
@using SICOVWEB_MCA.Models
@{
    ViewData["Title"] = "Lista de Productos";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

@model SICOVWEB_MCA.Helpers.Paginacion<SICOVWEB_MCA.Models.Producto>

<section class="contenedor-principal">
    <div class="header-seccion">
        <h2 class="titulo-seccion">Consulta de Productos</h2>
        <a asp-controller="Productos" asp-action="CrearProducto" class="btn-primario">Registrar Producto</a>
        <a asp-controller="Importador" asp-action="ImportadorExcelProductos" class="btn-primario">Importar Excel</a>
    </div>   
    
    <!-- ====== FILTROS DE BÚSQUEDA ====== -->
    <form asp-controller="Productos" asp-action="Buscar" method="get" id="formFiltros" class="filtros">
        <div class="grid-filtros">
            <!-- Filtrar por # id contacto -->
            <div>
                <label for="id">No. Producto:</label>
                <input type="text" id="id" name="id" class="input-filtro" />
            </div>
            <!-- Filtrar por Nombre de producto -->
            <div>
                <label for="nombre">Nombre Producto:</label>
                <input type="text" id="nombre" name="nombre" class="input-filtro" />
            </div>
            <!-- Filtrar por Razon social de Proveedor -->
            <div>
                <label for="razonSocial">Proveedor:</label>
                <input type="text" id="razonSocial" name="razonSocial" class="input-filtro" />
            </div>
            <!-- Filtrar por Marca -->
            <div>
                <label for="marca">Marca:</label>
                <input type="text" id="marca" name="marca" class="input-filtro" />
            </div>
            <div></div>
            <button type="submit" class="btn-buscar">Buscar</button>


        </div>
    </form>


    <h2>Lista de Productos</h2>
    <hr />
    <div class="tabla-container">
        <table id="tabla">
            <thead>
                <tr>
                    <th>No. producto</th>
                    <th>No. Proveedor</th>
                    <th>Razón Social</th>
                    <th>Nombre</th>
                    <th>Marca</th>
                    <th>Descripción</th>
                    <th>Precio de compra</th>
                    <th>Precio de venta</th>
                    <th>Unidades</th>
                    <th>Margen de ganancia %</th>
                    <th>Stock Actual</th>
                    <th>Stock Mínimo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Id_producto</td>
                            <!-- Colocar la Razon social del proveedor conociendo su idproveedor -->
                            <td>@p.Idproveedor</td>
                            <td>@($"{p.Proveedor.Razon_social}")</td>
                            <td>@p.Nombre</td>
                            <td>@p.Marca</td>
                            <td>@p.Descripcion</td>
                            <td>@p.Precio_Compra</td>
                            <td>@p.Precio_Venta</td>
                            <td>@p.Unidad</td>
                            <td>@p.Margen %</td>
                            <td>@p.StockActual</td>
                            <td>@p.StockMinimo</td>
                            <td class="acciones">
                                <a asp-controller="Productos" asp-action="EditarProducto" asp-route-id="@p.Id_producto" class="btn-editar"><i class="bi bi-pencil-square"></i></a>
                                <a asp-controller="Productos" asp-action="EliminarProducto" asp-route-id="@p.Id_producto" class="btn-borrar" onclick="return confirm('¿Estás seguro de que deseas eliminar este producto?');"><i class="bi bi-trash"></i></a>
                                <a asp-controller="Productos" asp-action="InfoProducto" asp-route-id="@p.Id_producto" class="btn-ver"><i class="bi bi-eye"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="10" class="sin-datos">No se encontraron resultados.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <!-- ====== PAGINACIÓN ====== -->
    <div class="paginacion">
        @if (Model.TienePaginaAnterior)
        {
            <a asp-action="@ViewContext.RouteData.Values["action"]"
               asp-route-pagina="@(Model.PaginaActual - 1)"
               asp-route-id="@ViewBag.Filtros?.id"
               asp-route-nombre="@ViewBag.Filtros?.nombre"
               asp-route-razonSocial="@ViewBag.Filtros?.razonSocial"
               asp-route-marca="@ViewBag.Filtros?.marca">« Anterior</a>
        }

        <span>Página @Model.PaginaActual de @Model.TotalPaginas</span>

        @if (Model.TienePaginaSiguiente)
        {
            <a asp-action="@ViewContext.RouteData.Values["action"]"
               asp-route-pagina="@(Model.PaginaActual + 1)"
               asp-route-id="@ViewBag.Filtros?.id"
               asp-route-nombre="@ViewBag.Filtros?.nombre"
               asp-route-razonSocial="@ViewBag.Filtros?.razonSocial"
               asp-route-marca="@ViewBag.Filtros?.marca">Siguiente »</a>
        }
    </div>
</section>
<div class="acciones-formulario">
    <!-- Botón para cargar productos con stock bajo -->
    <button id="btnStockBajo" class="btn-secundario">Ver productos con Stock Bajo</button>
</div>

<!-- Contenedor para la vista parcial -->
<div id="contenedorStockBajo"></div>


@section Scripts {
    <script>
        document.getElementById("btnStockBajo").addEventListener("click", function () {
            fetch("@Url.Action("ListaProductosStockBajo", "Productos")")
                .then(response => {
                    if (!response.ok) throw new Error("Error al cargar los productos");
                    return response.text();
                })
                .then(html => {
                    document.getElementById("contenedorStockBajo").innerHTML = html;
                })
                .catch(error => {
                    alert("Error: " + error.message);
                });
        });
    </script>
}
