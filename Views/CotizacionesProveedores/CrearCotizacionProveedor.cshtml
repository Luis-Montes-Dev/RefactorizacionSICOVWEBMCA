@model SICOVWEB_MCA.Models.Cotizacion_proveedor
@{
    ViewData["Title"] = "Crear Cotización de Proveedor";
    Layout = "~/Views/Shared/_Layout_admin.cshtml";
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
}

<section class="contenedor-principal">
    <div class="header-seccion">
        <h2 class="titulo-seccion">Registrar nueva cotización de proveedor</h2>
        <a asp-controller="CotizacionesProveedores" asp-action="Buscar" class="btn-secundario">
            <i class="bi bi-arrow-left"></i> Regresar
        </a>
    </div>
    <hr />

    <form asp-controller="CotizacionesProveedores" asp-action="CrearCotizacionProveedor" method="post" class="formulario-cotizacion">
        <input type="hidden" asp-for="Id_cotizacion" value="0" />
        <input type="hidden" asp-for="Estatus" value="pendiente" />

        <div class="form-grid">
            <div>
                <label asp-for="Id_Proveedor">Proveedor</label>
                <select id="Id_Proveedor" asp-for="Id_Proveedor" asp-items="ViewBag.Proveedores" class="campo-formulario">
                    <option value="">Seleccione un proveedor</option>
                </select>
                <span asp-validation-for="Id_Proveedor" class="text-danger"></span>
            </div>

            <div>
                <label>Generado por</label>
                <input type="text" value="@User.Identity.Name" class="campo-formulario" readonly />
            </div>

            <div>
                <label asp-for="Fecha">Fecha</label>
                <input asp-for="Fecha" type="date" value="@fechaActual" class="campo-formulario" readonly />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Fecha_Vigencia">Fecha de Vigencia</label>
                <input asp-for="Fecha_Vigencia" type="date" class="campo-formulario" />
                <span asp-validation-for="Fecha_Vigencia" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Tipo_Moneda">Tipo de Moneda</label>
                <select asp-for="Tipo_Moneda" class="campo-formulario">
                    <option value="">Seleccione</option>
                    <option value="MXN">MXN - Peso Mexicano</option>
                    <option value="USD">USD - Dólar Americano</option>
                </select>
                <span asp-validation-for="Tipo_Moneda" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Condiciones_Pago">Condiciones de Pago</label>
                <select asp-for="Condiciones_Pago" class="form-control">
                    <option value="">Seleccione una condición de pago</option>
                    <option value="Contado">Contado</option>
                    <option value="Crédito 15 días">Crédito 15 días</option>
                    <option value="Crédito 30 días">Crédito 30 días</option>
                    <option value="Crédito 60 días">Crédito 60 días</option>
                </select>
                <span asp-validation-for="Condiciones_Pago" class="text-danger"></span>
            </div>

            <div style="grid-column: 1 / span 2;">
                <label asp-for="Comentario">Comentario</label>
                <textarea asp-for="Comentario" class="campo-formulario" rows="2"></textarea>
                <span asp-validation-for="Comentario" class="text-danger"></span>
            </div>
        </div>

        <hr />
        <div class="tabla-container">        
        <table id="tablaProductos" class="tabla-detalles">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Descripción</th>
                    <th>Cantidad</th>
                    <th>Precio unitario</th>
                    <th>Subtotal</th>
                    <th>Tiempo entrega (días)</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><input name="Detalles[0].Nombre_producto" type="text" class="campo-formulario" placeholder="Nombre producto" /></td>
                    <td><input name="Detalles[0].Descripcion" type="text" class="campo-formulario" placeholder="Descripción" /></td>
                    <td><input name="Detalles[0].Cantidad" type="number" class="campo-formulario cantidad" min="1" /></td>
                    <td><input name="Detalles[0].Precio_Unitario" type="number" step="0.01" class="campo-formulario precio" /></td>
                    <td><input name="Detalles[0].Subtotal" type="number" class="campo-formulario subtotal" readonly /></td>
                    <td><input name="Detalles[0].Tiempo_Entrega" type="number" class="campo-formulario" placeholder="# días" /></td>
                    <td><button type="button" class="btn-borrar" onclick="eliminarFila(this)"><i class="bi bi-trash"></i></button></td>
                </tr>
            </tbody>
        </table>
        </div>
        <div class="acciones-detalle">
            <button type="button" onclick="agregarProducto()" class="btn-primario">
                <i class="bi bi-plus-circle"></i> Agregar Producto
            </button>
        </div>

        <div class="acciones-formulario">
            <button type="submit" class="btn-primario">
                <i class="bi bi-floppy"></i> Guardar
            </button>
            <button type="reset" class="btn-borrar">
                <i class="bi bi-eraser"></i> Limpiar
            </button>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        // Agregar fila
        function agregarProducto() {
            let index = $("#tablaProductos tbody tr").length;
            let row = `
                <tr>
                    <td><input name="Detalles[${index}].Nombre_producto" type="text" class="campo-formulario" placeholder="Nombre producto" /></td>
                    <td><input name="Detalles[${index}].Descripcion" type="text" class="campo-formulario" placeholder="Descripción" /></td>
                    <td><input name="Detalles[${index}].Cantidad" type="number" class="campo-formulario cantidad" min="1" /></td>
                    <td><input name="Detalles[${index}].Precio_Unitario" type="number" step="0.01" class="campo-formulario precio" /></td>
                    <td><input name="Detalles[${index}].Subtotal" type="number" class="campo-formulario subtotal" readonly /></td>
                    <td><input name="Detalles[${index}].Tiempo_Entrega" type="number" class="campo-formulario" placeholder="# días" /></td>
                    <td><button type="button" class="btn-borrar" onclick="eliminarFila(this)"><i class="bi bi-trash"></i></button></td>
                </tr>`;
            $("#tablaProductos tbody").append(row);
        }

        // Eliminar fila
        function eliminarFila(btn) {
            $(btn).closest("tr").remove();
        }

        // Calcular subtotales automáticamente
        $(document).on('input', '.cantidad, .precio', function () {
            let row = $(this).closest('tr');
            let cantidad = parseFloat(row.find('.cantidad').val()) || 0;
            let precio = parseFloat(row.find('.precio').val()) || 0;
            let subtotal = cantidad * precio;
            row.find('.subtotal').val(subtotal.toFixed(2));
        });
    </script>
}
